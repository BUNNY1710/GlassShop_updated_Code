# ── Database ──────────────────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=glass_shop
DB_USERNAME=postgres
DB_PASSWORD=Postgres

# ── JWT ───────────────────────────────────────────────────────────────────────
JWT_SECRET=change_this_to_a_long_random_secret_string
PORT=8080

# ── Environment ───────────────────────────────────────────────────────────────
# development  → tables auto-created/altered on startup, SQL logged to console
# production   → no auto-sync; run deploy/migrations manually
NODE_ENV=development

